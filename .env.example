# Arabic Video Translator - Environment Variables
# Copy to .env and customize

# Language settings
SOURCE_LANG=ar
TARGET_LANG=en

# Whisper model (tiny/base/small/medium/large)
WHISPER_MODEL=medium

# Watch mode
WATCH_INTERVAL=5
DELETE_SOURCE=false

# Device (auto-detected, override if needed)
# DEVICE=cuda
# DEVICE=cpu
